  "metrics": {
    "classification_accuracy": { "label": "Precisión de clasificación", "formula": "correct_placements / total_placements", "clinical_correlation": "categorización semántica, WCST categorías completadas" },
    "similarity_discrimination_score": { "label": "Discriminación de semejanzas", "formula": "correct_pairs / total_pairs", "clinical_correlation": "discriminación perceptual, subtest Semejanzas WAIS" },
    "seriation_accuracy": { "label": "Seriación", "formula": "items_in_correct_position / total_items", "clinical_correlation": "seriación numérica, subtest Matrices WAIS" },
    "calculation_accuracy": { "label": "Cálculo", "formula": "correct_answers / total_problems", "clinical_correlation": "aritmética, subtest Aritmética WAIS" },
    "grouping_precision": { "label": "Agrupamiento funcional", "formula": "(correct_selected - traps_selected) / total_correct", "clinical_correlation": "formación de conceptos, WCST, función ejecutiva" },
    "reasoning_score": { "label": "Razonamiento inferencial", "formula": "correct_inferences / total_scenarios", "clinical_correlation": "razonamiento abstracto, Tower of London, función ejecutiva" },
    "symbolization_score": { "label": "Simbolización", "formula": "correct_matches / total_matches", "clinical_correlation": "comprensión simbólica, abstracción, subtest Información WAIS" },
    "trap_inhibition_rate": { "label": "Inhibición de trampas", "formula": "1 - (traps_selected / traps_available)", "clinical_correlation": "control inhibitorio, Stroop, Go/No-Go" },
    "perseveration_index": { "label": "Índice de perseveración", "formula": "repeated_wrong_category_errors / total_errors", "clinical_correlation": "flexibilidad cognitiva, errores perseverativos WCST" },
    "time_per_decision": { "label": "Tiempo por decisión", "formula": "avg_ms_per_placement", "clinical_correlation": "velocidad de procesamiento, TMT-A" },
    "hesitation_pattern": { "label": "Patrón de vacilación", "formula": "moves_with_hover_>2s / total_moves", "clinical_correlation": "incertidumbre decisional, ansiedad de rendimiento" },
    "event_recovery_time": { "label": "Recuperación ante interrupción", "formula": "avg_ms_to_resume_after_event", "clinical_correlation": "atención sostenida, resiliencia atencional" }
  },

