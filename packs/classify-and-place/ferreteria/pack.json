    "calculation": [
      {
        "id": "cortar_cano",
        "name": "¿Cuántos tramos de caño?",
        "emoji": "🔵",
        "description": "El cliente necesita 7 metros de caño PVC de 40mm. Vienen en tramos de 4 metros. ¿Cuántos tramos necesita?",
        "type": "math_problem",
        "correct_answer": 2,
        "explanation": "7 ÷ 4 = 1,75 → necesitás 2 tramos (no podés comprar 1,75 tramos)",
        "cognitive_target": "cálculo con redondeo práctico",
        "min_difficulty": 3
      },
      {
        "id": "precio_clavos",
        "name": "El precio de los clavos",
        "emoji": "📌",
        "description": "El kilo de clavos de 2 pulgadas cuesta $2.800. El cliente necesita 250 gramos. ¿Cuánto le cobrás?",
        "type": "math_problem",
        "correct_answer": 700,
        "explanation": "250g = 1/4 de kilo → $2.800 ÷ 4 = $700",
        "cognitive_target": "cálculo proporcional",
        "min_difficulty": 2
      },
      {
        "id": "cable_habitacion",
        "name": "Cable para la habitación",
        "emoji": "〰️",
        "description": "Hay que cablear una habitación: 2 bocas de luz (3 metros de cable cada una) y 3 tomacorrientes (4 metros cada uno). ¿Cuántos metros de cable en total?",
        "type": "math_problem",
        "correct_answer": 18,
        "explanation": "(2 × 3) + (3 × 4) = 6 + 12 = 18 metros",
        "cognitive_target": "cálculo combinado con operaciones múltiples",
        "min_difficulty": 3
      },
      {
        "id": "presupuesto_pintura",
        "name": "Presupuesto de pintura",
        "emoji": "🪣",
        "description": "El cliente va a pintar una habitación de 4m x 3m, paredes de 2.5m de alto. Rinde 10m²/litro. ¿Cuántos litros necesita para UNA mano?",
        "type": "math_problem",
        "correct_answer": 3.5,
        "accept_range": [3, 4],
        "explanation": "Perímetro = 2×(4+3) = 14m. Superficie = 14 × 2.5 = 35m². 35 ÷ 10 = 3.5 litros",
        "cognitive_target": "cálculo geométrico aplicado + razonamiento secuencial",
        "min_difficulty": 5
      },
      {
        "id": "vuelto",
        "name": "El vuelto",
        "emoji": "💰",
        "description": "El cliente compró: 1 rodillo ($4.500) + 2 pinceles ($2.800 c/u) + 1 lija ($650). Paga con $15.000. ¿Cuánto de vuelto?",
        "type": "math_problem",
        "correct_answer": 4250,
        "explanation": "4500 + 2×2800 + 650 = 10.750. Vuelto = 15.000 - 10.750 = $4.250",
        "cognitive_target": "cálculo aritmético múltiple + sustracción",
        "min_difficulty": 3
      }
    ],

